class FilterManagementScreen extends StatefulWidget {
  const FilterManagementScreen({super.key});

  @override
  State<FilterManagementScreen> createState() => _FilterManagementScreenState();
}

class _FilterManagementScreenState extends State<FilterManagementScreen> {
  double sedimentLife = 0.85;
  double carbonLife = 0.90;
  double postLife = 0.92;

  void _simulateUsage() {
    setState(() {
      if (sedimentLife > 0.05) sedimentLife -= 0.05;
      if (carbonLife > 0.03) carbonLife -= 0.03;
      if (postLife > 0.02) postLife -= 0.02;
    });
  }

  void _handleOrder() {
    showDialog(
      context: context,
      builder: (context) => AlertDialog(
        title: const Text("Order Confirmed"),
        content: const Text("Your replacement cartridges are on the way! Would you like to reset the status?"),
        actions: [
          TextButton(
            onPressed: () => Navigator.pop(context),
            child: const Text("Cancel"),
          ),
          TextButton(
            onPressed: () {
              setState(() {
                sedimentLife = 1.0;
                carbonLife = 1.0;
                postLife = 1.0;
              });
              Navigator.pop(context);
            },
            child: const Text("Reset Filters"),
          ),
        ],
      ),
    );
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: Colors.white,
      appBar: AppBar(
        title: const Text('Filter Management',
            style: TextStyle(color: Colors.white, fontWeight: FontWeight.bold)),
        backgroundColor: const Color(0xFF4A7DAB),
        centerTitle: true,
        elevation: 0,
       leading: IconButton(
  icon: const Icon(Icons.arrow_back_ios, color: Colors.white),
  onPressed: () => Navigator.pop(context),
),
      ),
      body: Column(
        children: [
          Container(
            height: 20,
            decoration: const BoxDecoration(
              color: Color(0xFF4A7DAB),
              borderRadius: BorderRadius.only(
                bottomLeft: Radius.circular(25),
                bottomRight: Radius.circular(25),
              ),
            ),
          ),
          const SizedBox(height: 20),
          Padding(
            padding: const EdgeInsets.symmetric(horizontal: 20),
            child: Container(
              padding: const EdgeInsets.all(24.0),
              decoration: BoxDecoration(
                color: Colors.white,
                borderRadius: BorderRadius.circular(20),
                boxShadow: [
                  BoxShadow(
                    color: Colors.black.withAlpha(20),
                    blurRadius: 15,
                    offset: const Offset(0, 5),
                  )
                ],
              ),
              child: Column(
                crossAxisAlignment: CrossAxisAlignment.start,
                children: [
                  const Row(
                    children: [
                      Icon(Icons.waves, color: Color(0xFF4A7DAB), size: 28),
                      SizedBox(width: 10),
                      Text('Cartridge Status',
                          style: TextStyle(
                              fontSize: 24,
                              fontWeight: FontWeight.w800,
                              color: Color(0xFF2D3142))),
                    ],
                  ),
                  const SizedBox(height: 10),
                  const Divider(thickness: 1, color: Color(0xFFECEFF1)),
                  const SizedBox(height: 20),
                  _buildFilterStatus("Sediment Filter", sedimentLife,
                      "Estimated ${(sedimentLife * 8).toInt()} months left",
                      const Color(0xFFF9A825), Icons.hourglass_bottom),
                  const SizedBox(height: 30),
                  _buildFilterStatus("Carbon Filter", carbonLife,
                      "Estimated ${(carbonLife * 9).toInt()} months left",
                      const Color(0xFF29B6F6), Icons.layers),
                  const SizedBox(height: 30),
                  _buildFilterStatus("Post-Filter", postLife,
                      "Estimated ${(postLife * 9).toInt()} months left",
                      const Color(0xFF66BB6A), Icons.verified_user),
                ],
              ),
            ),
          ),
          const SizedBox(height: 20),
          TextButton.icon(
            onPressed: _simulateUsage,
            icon: const Icon(Icons.opacity, color: Color(0xFF4A7DAB)),
            label: const Text("Simulate Water Usage",
                style: TextStyle(color: Color(0xFF4A7DAB))),
          ),
          const Spacer(),
          Padding(
            padding: const EdgeInsets.fromLTRB(30, 0, 30, 40),
            child: SizedBox(
              width: double.infinity,
              height: 60,
              child: ElevatedButton(
                onPressed: _handleOrder,
                style: ElevatedButton.styleFrom(
                  backgroundColor: const Color(0xFF4A7DAB),
                  shape: RoundedRectangleBorder(
                      borderRadius: BorderRadius.circular(15)),
                  elevation: 4,
                ),
                child: const Text('Order Replacements',
                    style: TextStyle(
                        fontSize: 18,
                        fontWeight: FontWeight.bold,
                        color: Colors.white)),
              ),
            ),
          ),
        ],
      ),
    );
  }

  Widget _buildFilterStatus(String title, double percent, String description,
      Color barColor, IconData icon) {
    return Column(
      crossAxisAlignment: CrossAxisAlignment.start,
      children: [
        Row(
          mainAxisAlignment: MainAxisAlignment.spaceBetween,
          children: [
            Row(
              children: [
                Icon(icon, size: 18, color: Colors.blueGrey),
                const SizedBox(width: 8),
                Text(title,
                    style: const TextStyle(
                        fontWeight: FontWeight.bold,
                        fontSize: 16,
                        color: Color(0xFF475569))),
              ],
            ),
            Text("${(percent * 100).toInt()}%",
                style: TextStyle(
                    fontWeight: FontWeight.w900, fontSize: 16, color: barColor)),
          ],
        ),
        const SizedBox(height: 12),
        Stack(
          children: [
            Container(
              height: 10,
              width: double.infinity,
              decoration: BoxDecoration(
                color: const Color(0xFFECEFF1),
                borderRadius: BorderRadius.circular(10),
              ),
            ),
            AnimatedContainer(
              duration: const Duration(milliseconds: 600),
              curve: Curves.easeOutCubic,
              height: 10,
              width: (MediaQuery.of(context).size.width - 88) * percent,
              decoration: BoxDecoration(
                color: barColor,
                borderRadius: BorderRadius.circular(10),
                boxShadow: [
                  BoxShadow(
                    color: barColor.withAlpha(80),
                    blurRadius: 4,
                    offset: const Offset(0, 2),
                  )
                ],
              ),
            ),
          ],
        ),
        const SizedBox(height: 8),
        Text(description,
            style: const TextStyle(
                color: Colors.blueGrey,
                fontSize: 13,
                fontStyle: FontStyle.italic)),
      ],
    );
  }
}

